@model UniDesk.Web.Models.Ticket

@{
    ViewData["Title"] = "Szczegóły zgłoszenia";
    
    var statusBadgeClass = Model.Status switch
    {
        UniDesk.Web.Models.TicketStatus.New => "bg-info text-dark",
        UniDesk.Web.Models.TicketStatus.Open => "bg-warning text-dark",
        UniDesk.Web.Models.TicketStatus.Closed => "bg-success",
        _ => "bg-secondary"
    };
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Lista Zgłoszeń</a></li>
            <li class="breadcrumb-item active" aria-current="page">Zgłoszenie #@Model.Id</li>
        </ol>
    </nav>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0">
                <i class="bi bi-ticket-perforated me-2"></i>Zgłoszenie #@Model.Id
            </h4>
            <span class="badge rounded-pill @statusBadgeClass px-3 py-2 fs-6">
                @Model.Status
            </span>
        </div>
        
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-8">
                    <h2 class="display-6 fw-bold text-dark mb-3">@Model.Title</h2>
                    <p class="text-muted mb-4">
                        <i class="bi bi-calendar-event me-1"></i> 
                        Utworzono: <strong>@Model.CreatedAt.ToString("dd MMMM yyyy, HH:mm")</strong>
                    </p>
                    
                    <h5 class="fw-bold border-bottom pb-2">Opis problemu</h5>
                    <div class="p-3 bg-light rounded border mb-4" style="min-height: 150px; white-space: pre-wrap;">
                        @if (string.IsNullOrEmpty(Model.Description))
                        {
                            <span class="text-muted italic">Brak dodatkowego opisu dla tego zgłoszenia.</span>
                        }
                        else
                        {
                            @Model.Description
                        }
                    </div>
                </div>

                <div class="col-md-4 border-start">
                    <h5 class="fw-bold mb-3 text-center">Akcje</h5>
                    <div class="d-grid gap-2">
                        @if (Model.Status != UniDesk.Web.Models.TicketStatus.Closed)
                        {
                            <form asp-action="Close" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-danger btn-lg w-100 mb-2" 
                                        onclick="return confirm('Czy na pewno chcesz oznaczyć to zgłoszenie jako ROZWIĄZANE?')">
                                    <i class="bi bi-check-circle me-1"></i> Zamknij zgłoszenie
                                </button>
                            </form>
                        }
                        
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-arrow-left me-1"></i> Powrót do listy
                        </a>
                    </div>
                    
                    <div class="mt-4 p-3 bg-light rounded text-center small text-muted">
                        System UniDesk v0.5 <br>
                        Status bazy: Połączono
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>