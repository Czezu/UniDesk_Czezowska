@model IEnumerable<UniDesk.Web.Models.Ticket>

<h1>Lista Zgłoszeń</h1>
<p>
    <a asp-action="Create" class="btn btn-success">Stwórz nowe zgłoszenie</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tytuł</th>
            <th>Status</th>
            <th>Data</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ticket in Model)
        {
            <tr>
                <td>@ticket.Id</td>
                <td>@ticket.Title</td>
                <td>@ticket.Status</td>
                <td>@ticket.CreatedAt.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>